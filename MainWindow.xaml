<Window x:Class="Playnite_Copy.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WOOOOOOAAAAAHHHHHH" Height="450" Width="800" Icon="Assets/Icon.ico">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <Button Content="Add EXE" Click="AddExe_Click" Width="100" Margin="0,0,8,0"/>
            <Button Content="Remove Selected" Click="RemoveExe_Click" Width="120" Margin="0,0,8,0"/>
            <Button Content="Open Selected" Click="OpenExe_Click" Width="110"/>
        </StackPanel>

        <ListBox x:Name="SavedList" Grid.Row="1" />
        
        <TextBlock Grid.Row="2" Text="Double-click an item to open." HorizontalAlignment="Left" Margin="0,8,0,0"/>
    </Grid>
</Window>
